<?xml version="1.0" encoding="UTF-8"?>
<!-- PDF에서 긁어온 코드 -->
<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- Spring IoC Container에 등록할 Bean 추가 -> 가져올 클래스의 패키지명.클래스명 -->
	<bean class="com.yedam.app.xml.SamsungTV"/>
	<bean id="tv" class="com.yedam.app.xml.LGTV"/>
	
	<!-- DI 설정 -->
	<bean id="cf" class="com.yedam.app.xml.Chef"/>
	<bean class="com.yedam.app.xml.Restaurant">
	
		<!-- Setter Injection 세터, name에는 필드명이 들어감 set뒤에 필드명 -->
		<!-- ref : referance의 줄임말, 위에 있는 bean들 중에서 하나를 참조하겠다. (없으면 동작안함) -->
		<!--  property name="chef" ref="cf"/> -->
		
		<!-- Constructor Injection 생성자 -->
		<constructor-arg ref="cf"/>
	</bean>
</beans>